{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/netspeed",
        "network",
        "bluetooth",
        "pulseaudio",
        "cpu",
        "temperature",
        "memory",
        "battery",
        "tray",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "on-scroll-up":   "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "sort-by-number": true,
        "persistent-workspaces": {
            "1": [], "2": [], "3": [], "4": [], "5": []
        }
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
            "(.*)WezTerm":            "  WezTerm",
            "(.*)Thunar":             "َ°‰‹  Fichiers",
            "(.*)Neovim":             "  $1"
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A %d %B}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 10,
        "calendar": {
            "mode": "month",
            "format": {
                "today": "<span color='#6b9fff'><b><u>{}</u></b></span>"
            }
        }
    },

    "custom/netspeed": {
        "exec": "~/.config/waybar/scripts/netspeed.sh",
        "interval": 2,
        "format": "{}",
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "format-wifi":        "َ°¤¨  {essid}",
        "format-ethernet":    "َ°ˆ€  {ifname}",
        "format-disconnected":"َ°¤­  Off",
        "format-linked":      "َ°ˆ€  (no IP)",
        "tooltip-format-wifi":     "َ°¤¨ {essid}  {signalStrength}%\n{ipaddr} / {cidr}",
        "tooltip-format-ethernet": "َ°ˆ€ {ifname} â€” {ipaddr} / {cidr}",
        "on-click": "nm-connection-editor"
    },

    "bluetooth": {
        "format":           "َ°‚¯",
        "format-connected": "َ°‚±  {device_alias}",
        "format-disabled":  "َ°‚²",
        "format-off":       "َ°‚²",
        "tooltip-format":                    "{controller_alias}\n{num_connections} appareil(s)",
        "tooltip-format-connected":          "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected":"  {device_alias}",
        "on-click": "blueman-manager"
    },

    "pulseaudio": {
        "format":       "{icon}  {volume}%",
        "format-muted": "َ°‌ں  muet",
        "format-icons": {
            "headphone": "َ°‹‹",
            "headset":   "َ°‹ژ",
            "speaker":   "َ°“ƒ",
            "default":  ["َ°•؟","َ°–€","َ°•¾"]
        },
        "tooltip-format": "{desc} â€” {volume}%",
        "on-click":       "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 2
    },

    "cpu": {
        "format": "َ°چ›  {usage}%",
        "interval": 3,
        "tooltip-format": "Charge : {usage}%\nFrأ©quence moy. : {avg_frequency:.2f} GHz"
    },

    "temperature": {
        "critical-threshold": 85,
        "format":          "َ°”ڈ  {temperatureC}آ°C",
        "format-critical": "َ°¸پ  {temperatureC}آ°C",
        "interval": 5,
        "tooltip-format": "Tempأ©rature CPU : {temperatureC}آ°C"
    },

    "memory": {
        "format": "َ°¾†  {percentage}%",
        "tooltip-format": "RAM : {used:.1f} Go / {total:.1f} Go\nLibre : {avail:.1f} Go",
        "interval": 10
    },

    "battery": {
        "states": {
            "full":     100,
            "good":     80,
            "warning":  30,
            "critical": 15
        },
        "format":          "{icon}  {capacity}%",
        "format-full":     "َ°پ¹  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-plugged":  "َ°ڑ¥  {capacity}%",
        "format-icons":   ["َ°‚ژ","َ°پ؛","َ°پ»","َ°پ¼","َ°پ½","َ°پ¾","َ°پ؟","َ°‚€","َ°‚پ","َ°‚‚","َ°پ¹"],
        "tooltip-format":  "{timeTo}\nConso : {power:.1f} W",
        "interval": 30
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true
    },

    "custom/power": {
        "format": "âڈ»",
        "tooltip": false,
        "on-click": "~/.config/scripts/powermenu.sh"
    }
}
